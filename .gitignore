venv/
__pycache__/
.DS_Store
.pytest_cache/

# Locally-cached PDFs and per-disease data dumps (regenerated on every run,
# not used by the published dashboards — kept out of git to avoid bloat).
pdfs/
manual_pdfs/
manual_data/
sample_manual.pdf
sample_download

# Generated dashboards + feed. These are rebuilt from the JSON data on every
# run and published straight to GitHub Pages via the workflow, so they no
# longer need to live in git history (each rebuild was a ~1.7 MB diff).
index.html
manuals.html
feed.xml
api/
_site/

# Derived CSV exports — regenerated from the JSON each run and not served by
# the site, so kept out of git to avoid daily churn.
diseases.csv
disease_manuals.csv
manuals_index.csv
manuals_index.json
